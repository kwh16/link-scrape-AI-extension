{
  "manifest_version": 3,
  "name": "YouTube History AI Filter",
  "version": "1.0.0",
  "description": "Filter YouTube history using Gemini AI",
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-zmLbXejx.js"
      ],
      "matches": [
        "https://www.youtube.com/feed/history*"
      ]
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "resources": [
        "assets/index.ts-zmLbXejx.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
